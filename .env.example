# Social AI Radar Phase 3
# Copy to .env if you want local defaults. Scripts also accept CLI flags.

SOCIAL_RADAR_QUERY="AI Agent"
SOCIAL_RADAR_PLATFORM=x
SOCIAL_RADAR_DATE=2026-05-27
SOCIAL_RADAR_TIMEZONE=Asia/Taipei

# top, latest, media, people
X_SEARCH_TAB=top

# false keeps the browser visible for inspection.
HEADLESS=false

# Phase 3 X scraper browser mode.
# cdp = connect to a manually launched real Chrome session at SOCIAL_RADAR_CDP_URL.
# persistent = fallback Playwright-managed Chrome profile.
SOCIAL_RADAR_BROWSER_MODE=cdp
SOCIAL_RADAR_CDP_URL=http://127.0.0.1:9222

# Use --manual or set this to true to pause before extraction.
MANUAL_PAUSE=true

# Output locations.
RAW_OUTPUT_PATH=raw-posts.json
REPORT_OUTPUT_PATH=social-radar-report.md
OUTPUT_DIR=output

# Telegram Bot push notification.
# Do not commit real tokens.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
