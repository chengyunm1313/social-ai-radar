{
  "name": "social-ai-radar",
  "version": "0.7.0",
  "private": true,
  "description": "Social AI Radar Phase 3: Playwright semi-automated public post collection and analysis.",
  "type": "module",
  "scripts": {
    "scrape:x": "node scripts/scrape-x.js",
    "import:manual:x": "node scripts/import-manual-x.js",
    "analyze": "node scripts/analyze-posts.js",
    "radar:x": "npm run scrape:x && npm run analyze",
    "radar:hybrid:x": "node scripts/radar-hybrid-x.js",
    "radar:line:x": "node scripts/line-x.js",
    "radar:send:telegram": "node scripts/send-telegram.ts",
    "radar:daily:x": "node scripts/radar-daily-x.js",
    "history:snapshot": "node scripts/history-snapshot.js",
    "trends:analyze": "node scripts/analyze-trends.js",
    "radar": "npm run radar:x"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chengyunm1313/social-ai-radar.git"
  },
  "keywords": [],
